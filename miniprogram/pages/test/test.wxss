.container {
  min-height: 100vh;
  background: #1a0f0a;
  padding: 32rpx;
  color: #d4b896;
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
  color: #f5e6d3;
}
.loading {
  text-align: center;
  color: #b8a088;
  padding-top: 100rpx;
}
.error-box {
  background: rgba(205,92,92,0.15);
  padding: 24rpx;
  border-radius: 12rpx;
  color: #e8a0a0;
}
.content {
  font-size: 24rpx;
  line-height: 1.8;
}
.info-row {
  margin-bottom: 8rpx;
  word-break: break-all;
}
.label {
  color: #8b7355;
}
.player-section {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(139,90,43,0.12);
  border-radius: 16rpx;
}
.back-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 80rpx;
  background: rgba(139,90,43,0.1);
  color: #b8a088;
  border-radius: 16rpx;
  border: none;
}
