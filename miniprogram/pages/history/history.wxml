<view class="container">
  <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
    <view class="empty-icon">📝</view>
    <view class="empty-text">还没有游戏记录</view>
    <view class="empty-hint">去答一局题吧！</view>
  </view>

  <view class="record-list" wx:if="{{records.length > 0}}">
    <view class="record-item" wx:for="{{records}}" wx:key="_id">
      <view class="record-header">
        <view class="record-stars">
          <text wx:for="{{item.score.stars}}" wx:key="*this">⭐</text>
        </view>
        <view class="record-diff" wx:if="{{item.difficulty > 0}}">
          <text wx:if="{{item.difficulty === 1}}">🌱 简单</text>
          <text wx:elif="{{item.difficulty === 2}}">🔥 中等</text>
          <text wx:else>🔒 困难</text>
        </view>
        <view class="record-date">{{item.createdAt}}</view>
      </view>
      <view class="record-score">
        <text class="score-num">{{item.score.correctCount}}/{{item.score.totalQuestions}}</text>
        <text class="score-pct">{{item.score.percentage}}%</text>
      </view>
      <view class="record-eval">{{item.score.evaluation}}</view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
