.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a0f0a 0%, #2c1810 40%, #1a0f0a 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #b8a088;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #8b7355;
}

.loading {
  text-align: center;
  padding-top: 200rpx;
  color: #b8a088;
  font-size: 28rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background: rgba(139, 90, 43, 0.12);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  border: 1px solid rgba(139, 90, 43, 0.2);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-stars {
  font-size: 28rpx;
}

.record-diff {
  flex: 1;
  font-size: 22rpx;
  color: #c9a64e;
  padding: 2rpx 16rpx;
  background: rgba(201,166,78,0.1);
  border-radius: 10rpx;
}

.record-date {
  font-size: 24rpx;
  color: #8b7355;
}

.record-score {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.score-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #c9a64e;
}

.score-pct {
  font-size: 26rpx;
  color: #b8a088;
}

.record-eval {
  font-size: 26rpx;
  color: #d4b896;
  line-height: 1.6;
}
