/* ==================== 整体布局 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a0f0a 0%, #2c1810 40%, #1a0f0a 100%);
}

.screen {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* ==================== 开始界面 ==================== */
.start-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.logo-area {
  text-align: center;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.logo-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #f5e6d3;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #b8a088;
}

.difficulty-tag {
  margin-top: 16rpx;
  display: inline-block;
  padding: 8rpx 32rpx;
  background: rgba(201, 166, 78, 0.15);
  border: 1px solid rgba(201, 166, 78, 0.3);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #c9a64e;
}

.rules-card {
  background: rgba(139, 90, 43, 0.12);
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  width: 100%;
  max-width: 560rpx;
  border: 1px solid rgba(139, 90, 43, 0.25);
}

.rules-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #d4b896;
  margin-bottom: 20rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  font-size: 26rpx;
  color: #b8a088;
  line-height: 1.6;
}

.rule-item .highlight {
  color: #c9a64e;
  font-weight: 600;
}

.start-btn {
  width: 400rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #b8860b 0%, #8b6914 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(184, 134, 11, 0.3);
  transition: transform 0.2s;
}

.start-btn:active {
  transform: scale(0.96);
}

.start-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #f5e6d3;
  letter-spacing: 4rpx;
}

/* ==================== 答题界面 ==================== */
.game-screen {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 顶部进度 */
.game-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #b8a088;
}

.current-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #c9a64e;
}

.progress-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  transition: all 0.3s;
}

.dot.current {
  background: #c9a64e;
  box-shadow: 0 0 12rpx rgba(201, 166, 78, 0.5);
  width: 32rpx;
}

.dot.done {
  background: rgba(255, 255, 255, 0.25);
}

.dot.dot-correct {
  background: #6b8e23;
}

.dot.dot-wrong {
  background: #cd5c5c;
}

/* 音频区域 */
.audio-section {
  padding: 20rpx 0;
}

/* 题目 */
.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #f5e6d3;
  text-align: center;
  padding: 16rpx 0;
}

/* 选项 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(139, 90, 43, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(139, 90, 43, 0.2);
  transition: all 0.2s;
}

.option-card:active {
  background: rgba(139, 90, 43, 0.2);
  transform: scale(0.98);
}

.option-letter {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(201, 166, 78, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #c9a64e;
  flex-shrink: 0;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #e8d5c0;
}

.option-icon {
  width: 48rpx;
  text-align: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

/* 选项状态 */
.option-correct {
  background: rgba(107, 142, 35, 0.2);
  border-color: rgba(107, 142, 35, 0.5);
}

.option-correct .option-letter {
  background: rgba(107, 142, 35, 0.3);
  color: #8fbc8f;
}

.option-correct .option-icon {
  color: #8fbc8f;
}

.option-wrong {
  background: rgba(205, 92, 92, 0.2);
  border-color: rgba(205, 92, 92, 0.5);
}

.option-wrong .option-letter {
  background: rgba(205, 92, 92, 0.3);
  color: #e8a0a0;
}

.option-wrong .option-icon {
  color: #e8a0a0;
}

.option-dimmed {
  opacity: 0.35;
}

/* 反馈横幅 */
.feedback-banner {
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.feedback-banner.correct {
  background: rgba(107, 142, 35, 0.15);
  color: #8fbc8f;
}

.feedback-banner.wrong {
  background: rgba(205, 92, 92, 0.15);
  color: #e8a0a0;
}

/* ==================== 结果界面 ==================== */
.result-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding-bottom: 60rpx;
}

.result-header {
  text-align: center;
  padding-top: 40rpx;
}

.stars-row {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.star {
  font-size: 56rpx;
}

.star-filled {
  animation: popIn 0.3s ease-out;
}

.star-empty {
  opacity: 0.25;
}

@keyframes popIn {
  0% { transform: scale(0); }
  80% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f5e6d3;
  margin-bottom: 12rpx;
}

.result-score {
  font-size: 72rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #c9a64e, #daa520);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.result-percentage {
  font-size: 26rpx;
  color: #b8a088;
  margin-top: 8rpx;
}

.evaluation-card {
  background: rgba(139, 90, 43, 0.12);
  border-radius: 20rpx;
  padding: 28rpx 36rpx;
  width: 100%;
  max-width: 560rpx;
  text-align: center;
  font-size: 28rpx;
  color: #d4b896;
  line-height: 1.8;
  border: 1px solid rgba(139, 90, 43, 0.2);
}

/* 逐题回顾 */
.review-section {
  width: 100%;
  max-width: 560rpx;
}

.review-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d4b896;
  margin-bottom: 16rpx;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.review-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(139, 90, 43, 0.08);
  border-left: 6rpx solid transparent;
}

.review-correct {
  border-left-color: #6b8e23;
}

.review-wrong {
  border-left-color: #cd5c5c;
}

.review-number {
  font-size: 26rpx;
  font-weight: 600;
  color: #b8a088;
  flex-shrink: 0;
}

.review-detail {
  flex: 1;
}

.review-composer {
  font-size: 26rpx;
  color: #e8d5c0;
}

.review-answer {
  font-size: 24rpx;
  margin-top: 4rpx;
}

/* 按钮组 */
.result-actions {
  display: flex;
  gap: 24rpx;
  padding-top: 16rpx;
}

.restart-btn,
.share-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.restart-btn {
  background: linear-gradient(135deg, #b8860b 0%, #8b6914 100%);
  color: #f5e6d3;
  box-shadow: 0 8rpx 32rpx rgba(184, 134, 11, 0.3);
  padding: 0 48rpx;
}

.share-btn {
  background: rgba(139, 90, 43, 0.15);
  color: #d4b896;
  border: 2rpx solid rgba(139, 90, 43, 0.3);
  padding: 0 48rpx;
}

.bottom-actions {
  width: 100%;
  max-width: 560rpx;
}

.home-btn,
.suggest-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 26rpx;
  border: none;
}

.home-btn {
  background: rgba(139, 90, 43, 0.08);
  color: #b8a088;
  border: 1px solid rgba(139, 90, 43, 0.15);
}

.suggest-btn {
  background: rgba(201, 166, 78, 0.1);
  color: #c9a64e;
  border: 1px solid rgba(201, 166, 78, 0.25);
  transition: all 0.2s;
}

.suggest-btn.suggest-active {
  background: rgba(201, 166, 78, 0.2);
  border-color: rgba(201, 166, 78, 0.45);
}

/* 建议表单 */
.suggest-form {
  width: 100%;
  max-width: 560rpx;
  background: rgba(139, 90, 43, 0.08);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1px solid rgba(139, 90, 43, 0.2);
  animation: slideUp 0.3s ease-out;
}

.suggest-form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d4b896;
  margin-bottom: 24rpx;
}

.suggest-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(139, 90, 43, 0.1);
  border-radius: 14rpx;
  border: 1px solid rgba(139, 90, 43, 0.2);
  margin-bottom: 20rpx;
}

.picker-placeholder {
  color: #6b5b4a;
  font-size: 26rpx;
}

.picker-value {
  color: #e8d5c0;
  font-size: 26rpx;
}

.picker-arrow {
  font-size: 20rpx;
  color: #8b7355;
}

.suggest-textarea {
  width: 100%;
  height: 180rpx;
  background: rgba(139, 90, 43, 0.1);
  border-radius: 14rpx;
  border: 1px solid rgba(139, 90, 43, 0.2);
  padding: 20rpx 24rpx;
  color: #e8d5c0;
  font-size: 26rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.suggest-placeholder {
  color: #6b5b4a;
}

.suggest-submit-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #c9a64e 0%, #8b6914 100%);
  color: #f5e6d3;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.suggest-submit-btn[disabled] {
  background: rgba(139, 90, 43, 0.1);
  color: #5a4a3a;
}
