.container {
  min-height: 100vh;
  background: #1a0f0a;
  padding: 24rpx;
  box-sizing: border-box;
}

.stats-bar {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(139,90,43,0.12);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #d4b896;
}

.stats-detail { color: #8b7355; }

.tip-box {
  background: rgba(201,166,78,0.08);
  border: 1px solid rgba(201,166,78,0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #b8a088;
}

.q-item {
  background: rgba(139,90,43,0.08);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.q-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.q-type {
  font-size: 22rpx;
  color: #c9a64e;
  background: rgba(201,166,78,0.12);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.q-diff {
  font-size: 22rpx;
  color: #8b7355;
}

.q-body {
  font-size: 28rpx;
  color: #e8d5c0;
  margin-bottom: 12rpx;
}

.q-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.q-composer {
  font-size: 24rpx;
  color: #8b7355;
}

.del-btn {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #e8a0a0;
  background: rgba(205,92,92,0.15);
  border-radius: 8rpx;
  border: none;
}

.loading {
  text-align: center;
  padding-top: 100rpx;
  color: #b8a088;
}
