.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a0f0a 0%, #2c1810 40%, #1a0f0a 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #b8a088; margin-bottom: 12rpx; }
.empty-hint { font-size: 26rpx; color: #8b7355; }
.loading { text-align: center; padding-top: 200rpx; color: #b8a088; font-size: 28rpx; }

.board-header {
  display: flex;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #8b7355;
  border-bottom: 1px solid rgba(139,90,43,0.2);
  margin-bottom: 12rpx;
}

.board-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: rgba(139,90,43,0.08);
}

.board-item.is-me {
  background: rgba(201,166,78,0.15);
  border: 1px solid rgba(201,166,78,0.3);
}

.rank-col { width: 80rpx; text-align: center; font-size: 30rpx; color: #c9a64e; }
.rank-medal { font-size: 36rpx; }

.score-col { flex: 1; display: flex; flex-direction: column; }
.avg-score { font-size: 36rpx; font-weight: 700; color: #f5e6d3; }
.best-score { font-size: 22rpx; color: #8b7355; }

.games-col { font-size: 26rpx; color: #b8a088; text-align: right; }
