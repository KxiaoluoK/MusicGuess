.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-bg) 0%, #2c1810 40%, var(--color-bg) 100%);
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  margin-bottom: 12rpx;
}

.update-date {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-align: center;
  margin-bottom: 40rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-gold);
  margin-bottom: 12rpx;
}

.section-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.bold {
  font-weight: 600;
  color: var(--color-text);
}

.br {
  display: block;
  margin-top: 4rpx;
}
