<view class="container">
  <!-- 隐私政策弹窗 -->
  <view class="privacy-overlay" wx:if="{{showPrivacyModal}}">
    <view class="privacy-modal">
      <view class="privacy-modal-title">隐私政策</view>
      <view class="privacy-modal-body">
        为提供游戏记录和排行榜服务，本小程序需要获取您的微信 OpenID。您的数据仅用于本小程序，不会分享给第三方。详细信息请查看<text class="privacy-link" bindtap="goPrivacy">隐私政策</text>。
      </view>
      <view class="privacy-modal-actions">
        <button class="privacy-btn disagree" bindtap="onDisagree">暂不同意</button>
        <button class="privacy-btn agree" bindtap="agreePrivacy">同意</button>
      </view>
    </view>
  </view>

  <view class="logo-area">
    <view class="logo-icon">🎻</view>
    <view class="logo-title">Tune Hunt</view>
    <view class="logo-subtitle">听一段旋律，猜出答案</view>
  </view>

  <!-- 难度选择 -->
  <view class="section-title">选择难度</view>
  <view class="difficulty-area">
    <button class="diff-btn easy" bindtap="goGame" data-difficulty="1">
      <text class="diff-icon">🌱</text>
      <text class="diff-label">简单</text>
    </button>
    <button class="diff-btn medium" bindtap="goGame" data-difficulty="2">
      <text class="diff-icon">🔥</text>
      <text class="diff-label">中等</text>
    </button>
    <button class="diff-btn hard" disabled>
      <text class="diff-icon">🔒</text>
      <text class="diff-label">困难<text class="diff-hint"> · 敬请期待</text></text>
    </button>
  </view>

  <!-- 其他入口 -->
  <view class="menu-area">
    <button class="menu-btn" bindtap="goLeaderboard">
      <text class="menu-icon">🏆</text>
      <text class="menu-text">排行榜</text>
    </button>
    <button class="menu-btn" bindtap="goHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">历史记录</text>
    </button>
  </view>

  <view class="privacy-footer" bindtap="goPrivacy">隐私政策</view>
</view>
