.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a0f0a 0%, #2c1810 40%, #1a0f0a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  box-sizing: border-box;
}

.logo-area {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.logo-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f5e6d3;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.logo-subtitle {
  font-size: 26rpx;
  color: #b8a088;
}

.section-title {
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 20rpx;
}

.difficulty-area {
  display: flex;
  gap: 16rpx;
  width: 100%;
  max-width: 560rpx;
  margin-bottom: 40rpx;
}

.diff-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 140rpx;
  border-radius: 24rpx;
  border: none;
  position: relative;
}

.diff-btn.easy {
  background: linear-gradient(135deg, #6b8e23 0%, #556b2f 100%);
  box-shadow: 0 6rpx 20rpx rgba(107, 142, 35, 0.3);
}

.diff-btn.medium {
  background: linear-gradient(135deg, #cd853f 0%, #8b6914 100%);
  box-shadow: 0 6rpx 20rpx rgba(205, 133, 63, 0.3);
}

.diff-btn.hard {
  background: rgba(139, 90, 43, 0.1);
  border: 2rpx solid rgba(139, 90, 43, 0.2);
  opacity: 0.6;
}

.diff-icon {
  font-size: 36rpx;
}

.diff-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #f5e6d3;
}

.diff-hint {
  font-size: 18rpx;
  color: #8b7355;
}

.menu-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  max-width: 480rpx;
}

.menu-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(139, 90, 43, 0.12);
  border: 1px solid rgba(139, 90, 43, 0.2);
  color: #d4b896;
  font-size: 28rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 28rpx;
}

.admin-btn {
  opacity: 0.5;
}
