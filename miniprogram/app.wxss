/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: #1a0f0a;
  color: #f5e6d3;
  min-height: 100vh;
}

/* 彻底移除微信小程序 button 默认蓝色边框 */
button::after {
  border: none;
}

button {
  padding: 0;
  margin: 0;
  border: none;
  outline: none;
  -webkit-tap-highlight-color: transparent;
}
